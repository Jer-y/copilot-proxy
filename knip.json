{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "scripts/**/*.ts",
    "tests/**/*.test.ts",
    "tests/live/**/*.ts"
  ],
  "project": [
    "src/**/*.ts",
    "tests/**/*.ts",
    "scripts/**/*.ts",
    "*.config.{js,ts}"
  ],
  "ignoreExportsUsedInFile": true,
  "ignoreDependencies": [
    "@types/ws",
    "undici",
    "prettier-plugin-packagejson",
    "ws"
  ]
}
